# ─── Deployment-only secrets (used by scripts/deploy.js — NEVER commit real values) ───
STELLAR_ISSUER_SECRET=S...
STELLAR_ISSUER_PUBLIC=G...
STELLAR_DISTRIBUTOR_SECRET=S...
STELLAR_DISTRIBUTOR_PUBLIC=G...

# ─── Public client config (baked into the Next.js bundle at build time) ───
# These MUST use the NEXT_PUBLIC_ prefix because the frontend reads them in the browser.
# Pre-filled with the live SecureStream testnet deployment (see deployments/testnet.json).
NEXT_PUBLIC_POOL_CONTRACT_ADDRESS=CAWL62KWM4PYN25BMG7UGZTNGZUO4J7Z4H27DJICRR56CEJEVG5FY2CG
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS=CCELLZIVJGLIGBPSPW225663T5FPMMZOMYQV62M5XC6R7PAMQF2NP2T2
NEXT_PUBLIC_BRIDGE_CONTRACT_ADDRESS=CCAFRHHLYRUKGKKEZMGGTNGH33QPZKIINLHAHA7U2TEB7WM5Z4VSLIFG
NEXT_PUBLIC_XLM_CONTRACT_ADDRESS=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Network / RPC / Horizon
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

